<UserControl x:Class="Rodent.App.Controls.MouseButtonsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
    </Grid.RowDefinitions>

    <!-- Profile picker + onboard-mode warning -->
    <StackPanel Grid.Row="0" Margin="24,14,24,0">
      <StackPanel Orientation="Horizontal">
        <TextBlock Text="Profile" Foreground="{StaticResource Muted}" FontSize="13" VerticalAlignment="Center"/>
        <ComboBox x:Name="ProfileCombo" MinWidth="230" Margin="10,0,10,0" SelectionChanged="ProfileCombo_Changed"/>
        <Button x:Name="NewProfileBtn" Content="+ New profile" Click="NewProfile_Click"/>
        <Button x:Name="CopyOnboardBtn" Content="Copy to onboard…" Margin="10,0,0,0" Visibility="Collapsed"
                ToolTip="Flash this profile's side-button bindings into the mouse so they work without Rodent (or on another PC)"
                Click="CopyOnboard_Click"/>
      </StackPanel>
      <Border x:Name="ModeBanner" Visibility="Collapsed" Background="#33E4A035" BorderBrush="#66E4A035"
              BorderThickness="1" CornerRadius="8" Padding="12,8" Margin="0,10,0,0">
        <StackPanel Orientation="Horizontal">
          <TextBlock x:Name="ModeBannerText" Foreground="{StaticResource Text}" FontSize="12" VerticalAlignment="Center"
                     Text="Onboard mode is off — assignments stored ON THE MOUSE (this Onboard profile) won't run. Per-app software actions still work."/>
          <Button Content="Turn on" Margin="12,0,0,0" Padding="10,4" Click="EnableMode_Click"/>
        </StackPanel>
      </Border>
      <Border x:Name="UntestedBanner" Visibility="Collapsed" Background="#33E4A035" BorderBrush="#66E4A035"
              BorderThickness="1" CornerRadius="8" Padding="12,8" Margin="0,10,0,0">
        <TextBlock x:Name="UntestedText" Foreground="{StaticResource Text}" FontSize="12" TextWrapping="Wrap"
                   Text="Experimental: this model hasn't been verified. Reading works, but onboard flash writes (button remaps, macros, DPI slots, saved lighting) assume the G402 memory layout and could be wrong on this device. Software per-app profiles are safe."/>
      </Border>
    </StackPanel>

    <Grid Grid.Row="1">
      <Viewbox Stretch="Uniform" Margin="12"
               RenderTransformOrigin="0.5,0.5">
        <Viewbox.RenderTransform>
          <ScaleTransform ScaleX="0.9" ScaleY="0.9"/>
        </Viewbox.RenderTransform>
        <Canvas x:Name="Root"/>
      </Viewbox>
      <TextBlock x:Name="NoArt" Text="No illustration for this device"
                 Foreground="{StaticResource Muted}" FontSize="13"
                 HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed"/>
      <!-- Transient status toast (write failures etc.) -->
      <Border x:Name="Toast" Visibility="Collapsed" HorizontalAlignment="Center" VerticalAlignment="Bottom"
              Margin="0,0,0,18" Background="{StaticResource Card}" BorderBrush="{StaticResource Border}"
              BorderThickness="1" CornerRadius="8" Padding="14,8">
        <TextBlock x:Name="ToastText" Foreground="{StaticResource Text}" FontSize="12" TextWrapping="Wrap" MaxWidth="420"/>
      </Border>
    </Grid>
  </Grid>
</UserControl>
