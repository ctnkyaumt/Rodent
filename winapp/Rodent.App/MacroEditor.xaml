<Window x:Class="Rodent.App.MacroEditor"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Macro Editor" Height="590" Width="720"
        WindowStartupLocation="CenterOwner" Background="{StaticResource Bg}"
        WindowStyle="None" ResizeMode="NoResize">
  <Window.Resources>
    <Style x:Key="TypeCard" TargetType="RadioButton">
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="RadioButton">
            <Border x:Name="B" Background="{StaticResource Card}" CornerRadius="8" Margin="4" Padding="10,12" Width="130"
                    BorderBrush="{StaticResource Border}" BorderThickness="1">
              <StackPanel>
                <TextBlock Text="{TemplateBinding Tag}" FontSize="24" HorizontalAlignment="Center" Foreground="{StaticResource Text}"/>
                <TextBlock Text="{TemplateBinding Content}" FontSize="11" TextAlignment="Center" TextWrapping="Wrap"
                           Foreground="{StaticResource Muted}" Margin="0,8,0,0"/>
              </StackPanel>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsChecked" Value="True">
                <Setter TargetName="B" Property="BorderBrush" Value="{StaticResource Accent}"/>
                <Setter TargetName="B" Property="Background" Value="{StaticResource Panel}"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
    <Style x:Key="AddBtn" TargetType="Button">
      <Setter Property="Foreground" Value="{StaticResource Text}"/>
      <Setter Property="Background" Value="{StaticResource Card}"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Padding" Value="14,7"/>
      <Setter Property="Margin" Value="0,0,8,0"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="B" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
              <ContentPresenter HorizontalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="B" Property="Background" Value="{StaticResource Accent}"/></Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
  </Window.Resources>

  <Border BorderBrush="{StaticResource Border}" BorderThickness="1">
   <DockPanel>
    <!-- Dark title bar (the native one would be light) -->
    <Border DockPanel.Dock="Top" Background="{StaticResource Panel}" Height="36"
            MouseLeftButtonDown="TitleBar_Drag">
      <Grid>
        <TextBlock Text="Macro Editor" Foreground="{StaticResource Text}" FontSize="13" FontWeight="SemiBold"
                   VerticalAlignment="Center" Margin="14,0,0,0"/>
        <Button Content="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="10" Width="40" Height="36"
                HorizontalAlignment="Right" Background="Transparent" BorderThickness="0"
                Foreground="{StaticResource Muted}" Padding="0" Click="CloseBtn_Click"/>
      </Grid>
    </Border>

    <Grid Margin="20">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <!-- Saved macros + name -->
    <StackPanel Grid.Row="0">
      <StackPanel Orientation="Horizontal">
        <TextBlock Text="Saved macros" Foreground="{StaticResource Muted}" VerticalAlignment="Center" FontSize="13"/>
        <ComboBox x:Name="SavedCombo" Width="220" Margin="12,0,8,0"/>
        <Button Content="Load" Width="70" Margin="0,0,6,0" Click="LoadSaved_Click"/>
        <Button Content="Delete" Width="70" Click="DeleteSaved_Click"/>
      </StackPanel>
      <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
        <TextBlock Text="Macro name" Foreground="{StaticResource Muted}" VerticalAlignment="Center" FontSize="13"/>
        <TextBox x:Name="NameBox" Width="240" Margin="12,0,0,0" FontSize="14" Text="Macro"/>
      </StackPanel>
    </StackPanel>

    <!-- Type -->
    <TextBlock Grid.Row="1" x:Name="TypeHint" Text="Macro type (stored on the mouse)" Foreground="{StaticResource Muted}" FontSize="13" Margin="0,16,0,4"/>
    <StackPanel Grid.Row="2">
      <StackPanel Orientation="Horizontal">
        <RadioButton x:Name="TypeOnce" Style="{StaticResource TypeCard}" GroupName="mt" IsChecked="True" Tag="→" Content="No Repeat"/>
        <RadioButton x:Name="TypeHeld" Style="{StaticResource TypeCard}" GroupName="mt" Tag="⟳" Content="Repeat While Held"/>
        <!-- Toggle can't be an onboard macro: the G402 firmware never cancels a
             repeat-until-cancel macro on re-press (fails in G HUB too). The working
             toggle is a per-app SOFTWARE action instead. -->
        <RadioButton x:Name="TypeToggle" Style="{StaticResource TypeCard}" GroupName="mt" Tag="⊙"
                     Content="Toggle — see note below" IsEnabled="False" Opacity="0.5"/>
      </StackPanel>
      <TextBlock x:Name="ToggleNote" Foreground="{StaticResource Muted}" FontSize="11" TextWrapping="Wrap" Margin="4,6,0,0" MaxWidth="560"
                 Text="Toggle (press to start, press to stop) can't live on the mouse — its chip won't cancel a running macro. For a real toggle, use a per-app profile: Assignments tab → pick a profile → click a side button → “Create macro” with type Toggle. That runs in Rodent and always stops (also Esc, also auto-stops)."/>
    </StackPanel>

    <!-- Options + add buttons -->
    <DockPanel Grid.Row="3" Margin="0,16,0,8">
      <CheckBox x:Name="StdDelay" DockPanel.Dock="Right" IsChecked="True" VerticalAlignment="Center"
                Content="50ms between actions" Foreground="{StaticResource Text}"/>
      <StackPanel Orientation="Horizontal">
        <Button x:Name="RecordBtn" Style="{StaticResource AddBtn}" Content="● Record keys + clicks" Focusable="False" Click="Record_Click"/>
        <Button Style="{StaticResource AddBtn}" Content="+ Text" Click="AddText_Click"/>
        <Button Style="{StaticResource AddBtn}" Content="+ Key combo" Click="AddKey_Click"/>
        <Button Style="{StaticResource AddBtn}" Content="+ Delay" Click="AddDelay_Click"/>
      </StackPanel>
    </DockPanel>

    <!-- Action list -->
    <Border Grid.Row="4" Background="{StaticResource Panel}" CornerRadius="8" Padding="8">
      <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel x:Name="StepsList"/>
      </ScrollViewer>
    </Border>

    <!-- Buttons -->
    <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
      <Button Content="Cancel" Width="90" Margin="0,0,10,0" IsCancel="True"/>
      <Button x:Name="SaveBtn" Content="Save to button" Width="140" Click="Save_Click"/>
    </StackPanel>
    </Grid>
   </DockPanel>
  </Border>
</Window>
